REASON_CODE_RE = re.compile(r"^[a-z_]+(_\d+)?$")
POST_SUBMISSION_WARNING_RE = re.compile(r"^worker_exit_\d+_after_submission$")


def stats_count_lines(counts, limit=12, numeric=False):
    items = sorted(counts.items(), key=lambda item: item[0] if numeric else str(item[0]))
    if len(items) > limit:
        shown = items[:limit - 1]
        omitted = sum(count for _name, count in items[limit - 1:])
        existing_other = next((count for name, count in shown if name == "other"), 0)
        shown = [(name, count) for name, count in shown if name != "other"]
        shown.append(("other", existing_other + omitted))
        items = shown
    return ["- {}={}".format(name, count) for name, count in items] or ["- none"]


def cmd_stats(args):
    """Print bounded aggregate runtime evidence without write-capable locks."""
    require_orchestrator()
    relay_dir = require_relay_dir()
    active = load_all_tasks(relay_dir)
    archived = load_archived_tasks(relay_dir)
    located_tasks = [(task, False) for task in active] + [
        (task, True) for task in archived
    ]
    if not located_tasks:
        say("no task data")
        return

    statuses = {}
    attempts = {}
    reasons = {}
    capsule_chars = []
    warning_count = 0
    attempt_keys = set()
    receipt_phases = {phase: set() for phase in ("edit", "verify", "report")}
    receipt_name = re.compile(r"^attempt-(\d+)\.briefs\.json$")

    for task, archived_task in located_tasks:
        status = task.get("status")
        status_code = status if status in STATUSES else "other"
        statuses[status_code] = statuses.get(status_code, 0) + 1
        attempt = task.get("attempt")
        if isinstance(attempt, int) and not isinstance(attempt, bool) and attempt > 0:
            attempts[attempt] = attempts.get(attempt, 0) + 1

        relevant_exits = []
        warning_entries = 0
        history = task.get("history", [])
        if not isinstance(history, list):
            history = []
        for entry in history:
            if not isinstance(entry, dict) or entry.get("event") not in {
                    "launched", "worker_exited"}:
                continue
            entry_attempt = entry.get("attempt")
            if entry.get("event") == "launched":
                if (
                        isinstance(entry_attempt, int)
                        and not isinstance(entry_attempt, bool)
                        and entry_attempt > 0):
                    attempt_keys.add((task.get("id"), entry_attempt))
                chars = entry.get("capsule_chars")
                if isinstance(chars, int) and not isinstance(chars, bool) and chars >= 0:
                    capsule_chars.append(chars)
            else:
                if entry.get("status") in {"failed", "blocked"}:
                    relevant_exits.append(entry)
                if (
                        isinstance(entry.get("warning"), str)
                        and POST_SUBMISSION_WARNING_RE.fullmatch(entry["warning"])):
                    warning_count += 1
                    warning_entries += 1
        if relevant_exits:
            for entry in relevant_exits:
                note = entry.get("note")
                code = note if isinstance(note, str) and REASON_CODE_RE.fullmatch(note) else "other"
                reasons[code] = reasons.get(code, 0) + 1
        elif status in {"failed", "blocked"}:
            note = task.get("last_note")
            code = note if isinstance(note, str) and REASON_CODE_RE.fullmatch(note) else "other"
            reasons[code] = reasons.get(code, 0) + 1
        if (
                not warning_entries
                and isinstance(task.get("warning"), str)
                and POST_SUBMISSION_WARNING_RE.fullmatch(task["warning"])):
            warning_count += 1

        task_id = task.get("id")
        if not isinstance(task_id, str) or not TASK_ID_RE.fullmatch(task_id):
            continue
        directory = (
            os.path.join(archive_dir(relay_dir), task_id + ".work")
            if archived_task else work_dir(relay_dir, task_id)
        )
        try:
            names = sorted(os.listdir(directory))
        except OSError:
            names = []
        for name in names:
            match = receipt_name.fullmatch(name)
            if not match:
                continue
            receipt_attempt = int(match.group(1))
            receipts = read_phase_receipts(
                os.path.join(directory, name), task_id, receipt_attempt,
            )
            if receipts is None:
                continue
            key = (task_id, receipt_attempt)
            attempt_keys.add(key)
            for phase in receipt_phases:
                if phase in receipts["phases"]:
                    receipt_phases[phase].add(key)

    say("Status counts:")
    for line in stats_count_lines(statuses):
        say(line)
    say("Attempts histogram:")
    for line in stats_count_lines(attempts, numeric=True):
        say(line)
    say("Failure/blocked reason codes:")
    for line in stats_count_lines(reasons):
        say(line)
    say("Capsule chars:")
    if capsule_chars:
        ordered_chars = sorted(capsule_chars)
        say("- min={} median={} max={}".format(
            ordered_chars[0], ordered_chars[(len(ordered_chars) - 1) // 2],
            ordered_chars[-1],
        ))
    else:
        say("- none recorded")
    say("Phase brief coverage (command-use evidence, not proof of attention):")
    denominator = len(attempt_keys)
    for phase in ("edit", "verify", "report"):
        say("- {}={}/{}".format(phase, len(receipt_phases[phase]), denominator))
    say("Post-submission warnings: {}".format(warning_count))


def dependency_cycles(tasks):
    by_id = {task.get("id"): task for task in tasks}
    visiting: list[str] = []
    visited = set()
    cycles = []

    def visit(task_id):
        if task_id in visiting:
            start = visiting.index(task_id)
            cycles.append([*visiting[start:], task_id])
            return
        if task_id in visited or task_id not in by_id:
            return
        visiting.append(task_id)
        for dependency in by_id[task_id].get("depends_on", []):
            if dependency in by_id:
                visit(dependency)
        visiting.pop()
        visited.add(task_id)

    for task_id in by_id:
        visit(task_id)
    return cycles


def task_problems(
        relay_dir, task, known_tasks, memory_entries, capsule_max_chars=None):
    problems = []
    task_id = task.get("id")
    prefix = str(task_id or "unknown") + ": "
    valid_id = True
    try:
        validate_task_id(task_id)
    except (TypeError, ValueError) as error:
        valid_id = False
        problems.append(prefix + str(error))
    if task.get("status") not in STATUSES:
        problems.append(prefix + "invalid status {!r}".format(task.get("status")))
    for field in ("title", "tier", "created_at", "updated_at"):
        if not isinstance(task.get(field), str) or not task[field]:
            problems.append(prefix + "{} must be non-empty text".format(field))
    if not isinstance(task.get("history"), list):
        problems.append(prefix + "history must be a list")
    if valid_id and not os.path.exists(task_json_path(relay_dir, task_id)):
        problems.append(prefix + "state filename does not match its id")
    attempt = task.get("attempt")
    if isinstance(attempt, bool) or not isinstance(attempt, int) or attempt < 1:
        problems.append(prefix + "attempt must be a positive integer")
    scopes = task.get("scope")
    if not isinstance(scopes, list):
        problems.append(prefix + "scope must be a list")
    else:
        try:
            if normalize_scopes(scopes) != scopes:
                problems.append(prefix + "scope is not canonical")
        except ValueError as error:
            problems.append(prefix + str(error))
    dependencies = task.get("depends_on")
    if not isinstance(dependencies, list) or not all(isinstance(item, str) for item in dependencies):
        problems.append(prefix + "depends_on must be a list of task ids")
    else:
        if len(dependencies) != len(set(dependencies)):
            problems.append(prefix + "duplicate dependencies")
        if task_id in dependencies:
            problems.append(prefix + "self dependency")
        for dependency in dependencies:
            if dependency not in known_tasks:
                problems.append(prefix + "unknown dependency {}".format(dependency))
            elif known_tasks[dependency].get("status") == "cancelled":
                problems.append(prefix + "cancelled dependency {}".format(dependency))
    runner = task.get("runner")
    if task.get("status") == "running":
        if not isinstance(runner, dict):
            problems.append(prefix + "running task needs runner metadata")
        else:
            if not isinstance(runner.get("lease"), str) or not runner["lease"]:
                problems.append(prefix + "running task lease is missing")
            if not pid_alive(runner.get("pid")):
                problems.append(prefix + "running worker is stale")
    elif runner:
        problems.append(prefix + "runner exists while task is not running")
    if (valid_id and task.get("status") == "needs_review"
            and not report_is_ready(report_path(
                relay_dir, task_id, task.get("attempt", 1),
            ))):
        problems.append(prefix + "review report is missing or invalid")
    violations = task.get("scope_violations")
    if violations:
        if task.get("status") not in ("blocked", "failed"):
            problems.append(prefix + "scope violations require blocked or failed status")
        if not task.get("scope_baseline"):
            problems.append(prefix + "scope violation baseline is missing")
    elif task.get("scope_baseline"):
        problems.append(prefix + "scope baseline exists without violations")
    if valid_id and task.get("status") == "queued" and capsule_max_chars is not None:
        spec_path = task_md_path(relay_dir, task_id)
        if os.path.exists(spec_path):
            try:
                with open(spec_path, encoding="utf-8") as source:
                    compile_context_capsule(
                        task, source.read(), memory_entries, capsule_max_chars,
                    )
            except (OSError, UnicodeDecodeError, ValueError) as error:
                problems.append(str(error))
    return problems


def cmd_validate(args):
    relay_dir = require_relay_dir()
    problems = []
    root = project_root(relay_dir)
    if not is_git_repo(root):
        problems.append("repository: not a Git worktree")
    else:
        try:
            top_level = git_checked(root, "rev-parse", "--show-toplevel").strip()
            if os.path.realpath(root) != os.path.realpath(top_level):
                problems.append("repository: Relay is not at the worktree root")
            submodules = git_submodule_paths(root)
            if submodules:
                problems.append(
                    "repository: tracked submodules are unsupported: "
                    + ", ".join(submodules)
                )
        except RuntimeError as error:
            problems.append("repository: " + str(error))
    capsule_max_chars = None
    memory_entries = ()
    try:
        config = load_config(relay_dir)
        configured_limits(config)
        capsule_max_chars = configured_capsule_max_chars(config)
        configured_finish_requires_brief(config)
        configured_report_requires_sections(config)
        configured_accept_requires_brief(config)
        configured_phase_sequence_requires_briefs(config)
        sample = {"tier": "default"}
        template = command_template(config, sample)
        if not isinstance(template, str) or not template.strip():
            problems.append("config: missing worker command")
        else:
            tokens = shlex.split(template)
            placeholders = [token for token in tokens if token in ("{prompt}", "{prompt_file}")]
            embedded = [
                token for token in tokens
                if ("{prompt}" in token or "{prompt_file}" in token)
                and token not in ("{prompt}", "{prompt_file}")
            ]
            if len(placeholders) != 1:
                problems.append("config: worker command needs one prompt placeholder")
            if embedded:
                problems.append("config: prompt placeholder must be a complete argument")
    except (SystemExit, ValueError) as error:
        problems.append("config: {}".format(error))
    try:
        _, memory_text = read_memory(relay_dir)
        memory_entries = memory_index_entries(memory_text)
    except (OSError, UnicodeDecodeError, ValueError) as error:
        problems.append("memory: {}".format(error))
    try:
        active = load_all_tasks(relay_dir)
        archived = load_archived_tasks(relay_dir)
    except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
        say("PROBLEM: cannot read task state: {}".format(error))
        raise SystemExit(1) from error
    all_tasks = active + archived
    known = {task.get("id"): task for task in all_tasks}
    seen_ids = set()
    seen_numbers: dict[int, str] = {}
    for task in all_tasks:
        task_id = task.get("id")
        if not isinstance(task_id, str):
            problems.append("task state has a non-string id")
            continue
        try:
            validate_task_id(task_id)
        except ValueError as error:
            problems.append("{}: {}".format(task_id, error))
            continue
        if task_id in seen_ids:
            problems.append("duplicate task id: {}".format(task_id))
        seen_ids.add(task_id)
        if TASK_ID_RE.fullmatch(task_id):
            number = int(task_id[1:task_id.index("-")])
            previous_id = seen_numbers.get(number)
            if previous_id and previous_id != task_id:
                problems.append(
                    "task number {} is reused by {} and {}".format(
                        number, previous_id, task_id,
                    )
                )
            seen_numbers[number] = task_id
    for task in active:
        problems.extend(task_problems(
            relay_dir, task, known, memory_entries,
            capsule_max_chars=capsule_max_chars,
        ))
        task_id = task.get("id")
        if isinstance(task_id, str) and TASK_ID_RE.fullmatch(task_id):
            if not os.path.exists(task_md_path(relay_dir, task_id)):
                problems.append("{}: task spec is missing".format(task_id))
    running = [task for task in active if task.get("status") == "running"]
    for index, first in enumerate(running):
        for second in running[index + 1:]:
            if scopes_overlap(first.get("scope", []), second.get("scope", [])):
                problems.append("running tasks {} and {} have overlapping scopes".format(
                    first["id"], second["id"],
                ))
    for cycle in dependency_cycles(active):
        problems.append("dependency cycle: " + " -> ".join(cycle))
    if problems:
        for problem in problems:
            say("PROBLEM: " + problem)
        raise SystemExit(1)
    say("ok: %d active task(s)" % len(active))


def cmd_archive(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    destination = archive_dir(relay_dir)
    os.makedirs(destination, exist_ok=True)
    with file_lock(lock_path(relay_dir, "scheduler")):
        eligible = [
            task for task in load_all_tasks(relay_dir)
            if task["status"] in ("done", "cancelled")
        ]
        plan = []
        for task in eligible:
            task_id = task["id"]
            for source in (
                    task_json_path(relay_dir, task_id),
                    task_md_path(relay_dir, task_id)):
                if os.path.exists(source):
                    plan.append((source, os.path.join(destination, os.path.basename(source))))
            source_work = work_dir(relay_dir, task_id)
            if os.path.isdir(source_work):
                plan.append((source_work, os.path.join(destination, task_id + ".work")))
        for _source, target in plan:
            if os.path.lexists(target):
                die("archive destination already exists: {}".format(target))
        blocked_signals = {signal.SIGINT, signal.SIGTERM}
        if hasattr(signal, "SIGHUP"):
            blocked_signals.add(signal.SIGHUP)
        previous_mask = signal.pthread_sigmask(signal.SIG_BLOCK, blocked_signals)
        completed = []
        try:
            for source, target in plan:
                shutil.move(source, target)
                completed.append((source, target))
        except BaseException:
            for source, target in reversed(completed):
                with suppress(OSError):
                    shutil.move(target, source)
            raise
        finally:
            signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)
    say("archived %d task(s)" % len(eligible))


# Memory

def memory_path(relay_dir):
    return os.path.join(relay_dir, "memory.md")


def read_memory(relay_dir):
    path = memory_path(relay_dir)
    if not os.path.exists(path):
        die("missing memory.md")
    with open(path, encoding="utf-8") as source:
        return path, source.read()


def memory_index_entries(text):
    """Parse the strict memory index as ordered (id, audience, summary) tuples."""
    marker = re.search(r"^## Index[ \t]*$", text, re.MULTILINE)
    if not marker:
        raise ValueError("memory index is missing; expected a '## Index' section")
    following = re.search(r"^## [^\n]+[ \t]*$", text[marker.end():], re.MULTILINE)
    end = marker.end() + following.start() if following else len(text)
    entries = []
    seen = set()
    marker_line = text.count("\n", 0, marker.end()) + 1
    pattern = re.compile(r"- (M\d{3,}) \[([WOB])\] (\S(?:.*\S)?)")
    for offset, line in enumerate(text[marker.end():end].splitlines()):
        if not line:
            continue
        line_number = marker_line + offset
        match = pattern.fullmatch(line)
        if not match:
            raise ValueError(
                "memory index line {} is malformed; expected '- M### [W|O|B] "
                "summary': {!r}".format(line_number, line)
            )
        memory_id, audience, summary = match.groups()
        if memory_id in seen:
            raise ValueError(
                "memory index has duplicate id {} at line {}".format(
                    memory_id, line_number,
                )
            )
        seen.add(memory_id)
        entries.append((memory_id, audience, summary))
    return entries


def cmd_memory_index(args):
    relay_dir = require_relay_dir()
    _, text = read_memory(relay_dir)
    audience = {"worker": "W", "orchestrator": "O"}.get(args.audience)
    for entry in memory_index_entries(text):
        if audience is None or entry[1] in (audience, "B"):
            say("{} [{}] {}".format(*entry))


def cmd_memory_show(args):
    relay_dir = require_relay_dir()
    _, text = read_memory(relay_dir)
    match = re.search(
        r"^### {} .*?(?=^### M|\Z)".format(re.escape(args.id)),
        text, re.MULTILINE | re.DOTALL,
    )
    if not match:
        die("no memory entry {}".format(args.id))
        return
    say(match.group(0).strip())


def cmd_memory_add(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    with file_lock(lock_path(relay_dir, "memory")):
        path, text = read_memory(relay_dir)
        entries = memory_index_entries(text)
        tag = {"worker": "W", "orchestrator": "O", "both": "B"}[args.audience]
        numbers = [int(memory_id[1:]) for memory_id, _audience, _summary in entries] or [0]
        memory_id = "M%03d" % (max(numbers) + 1)
        index_line = "- {} [{}] {}".format(memory_id, tag, args.summary)
        entry = "### {} [{}] {}\n{}\n".format(memory_id, tag, args.summary, args.body)
        if "## Entries" in text:
            head, marker, tail = text.partition("## Entries")
            text = head.rstrip() + "\n" + index_line + "\n\n" + marker
            if tail.strip():
                text += tail.rstrip() + "\n\n"
            else:
                text += "\n\n"
            text += entry
        else:
            text = text.rstrip() + "\n" + index_line + "\n\n## Entries\n\n" + entry
        atomic_write(path, text)
    say("added {}".format(memory_id))


# Init and CLI

def cmd_init(args):
    require_orchestrator()
    target = os.path.abspath(args.path or ".")
    if not os.path.isdir(target):
        die("no such directory: {}".format(target))
    require_git_root(target)
    source = script_dir()
    relay_dir = os.path.join(target, RELAY_DIRNAME)
    runtime_paths_are_safe(relay_dir)
    static_files = ("relay", "orchestrator.md", "worker.md")
    missing = [name for name in static_files if not os.path.exists(os.path.join(source, name))]
    memory_source = os.path.join(source, "memory.md")
    config_source = os.path.join(source, "config.example.toml")
    if not os.path.exists(config_source):
        config_source = os.path.join(source, "config.toml")
    if not os.path.exists(memory_source):
        missing.append("memory.md")
    if not os.path.exists(config_source):
        missing.append("config.example.toml or config.toml")
    if missing:
        die("framework files missing beside relay: {}".format(", ".join(missing)))
    os.makedirs(relay_dir, exist_ok=True)
    for name in static_files:
        destination = os.path.join(relay_dir, name)
        if os.path.exists(destination) and not args.force:
            continue
        if os.path.abspath(os.path.join(source, name)) != os.path.abspath(destination):
            shutil.copy2(os.path.join(source, name), destination)
    os.chmod(os.path.join(relay_dir, "relay"), 0o700)
    destination_memory = os.path.join(relay_dir, "memory.md")
    if not os.path.exists(destination_memory):
        shutil.copy2(memory_source, destination_memory)
    destination_config = os.path.join(relay_dir, "config.toml")
    if not os.path.exists(destination_config):
        shutil.copy2(config_source, destination_config)
    for subdirectory in ("tasks", "work", "archive", ".locks"):
        os.makedirs(os.path.join(relay_dir, subdirectory), exist_ok=True)
    gitignore = os.path.join(target, ".gitignore")
    existing = ""
    if os.path.exists(gitignore):
        with open(gitignore, encoding="utf-8") as source_file:
            existing = source_file.read()
    if RELAY_DIRNAME + "/" not in existing.splitlines():
        updated = existing
        if updated and not updated.endswith("\n"):
            updated += "\n"
        updated += RELAY_DIRNAME + "/\n"
        atomic_write(gitignore, updated)
        say("added .attention-relay/ to .gitignore")
    say("initialized {}".format(relay_dir))
    say("next: have your agent read .attention-relay/orchestrator.md and run .attention-relay/relay orchestrator brief --phase start")


def build_parser():
    parser = argparse.ArgumentParser(prog="relay", description=__doc__)
    commands = parser.add_subparsers(dest="command", required=True)

    command = commands.add_parser("init", help="install Attention Relay in a Git project")
    command.add_argument("path", nargs="?", help="project directory (default: .)")
    command.add_argument("--force", action="store_true", help="refresh relay and its manuals")
    command.set_defaults(function=cmd_init)

    task = commands.add_parser("task", help="manage tasks")
    task_commands = task.add_subparsers(dest="task_command", required=True)

    command = task_commands.add_parser("create", help="create a task")
    command.add_argument("--title", required=True)
    command.add_argument("--scope", action="append")
    command.add_argument("--depends-on", action="append", dest="depends_on")
    command.add_argument("--tier")
    command.set_defaults(function=cmd_task_create)

    command = task_commands.add_parser("list", help="list active tasks")
    command.add_argument("--json", action="store_true")
    command.set_defaults(function=cmd_task_list)

    command = task_commands.add_parser("show", help="show task state")
    command.add_argument("id")
    command.set_defaults(function=cmd_task_show)

    command = task_commands.add_parser("capsule", help="preview a task capsule and its budget")
    command.add_argument("id")
    command.add_argument("--raw", action="store_true", help="print only the capsule bytes")
    command.set_defaults(function=cmd_task_capsule)

    command = task_commands.add_parser("accept", help="approve reviewed work")
    command.add_argument("id")
    command.add_argument("--note")
    command.add_argument("--brief")
    command.set_defaults(function=cmd_task_accept)

    command = task_commands.add_parser("return", help="queue another attempt")
    command.add_argument("id")
    command.add_argument("--reason", required=True)
    command.set_defaults(function=cmd_task_return)

    command = task_commands.add_parser("decide", help="answer a worker question")
    command.add_argument("id")
    command.add_argument("--answer", required=True)
    command.set_defaults(function=cmd_task_decide)

    command = task_commands.add_parser("cancel", help="cancel a task")
    command.add_argument("id")
    command.add_argument("--reason")
    command.set_defaults(function=cmd_task_cancel)

    command = task_commands.add_parser("finish", help="submit a worker result")
    command.add_argument("id")
    command.add_argument("--status", required=True, choices=WORKER_FINAL)
    command.add_argument("--note")
    command.add_argument("--changed", action="append", default=[])
    command.add_argument("--brief")
    command.set_defaults(function=cmd_task_finish)

    command = task_commands.add_parser("brief", help="reprint the worker capsule and phase checklist")
    command.add_argument("id")
    command.add_argument("--phase", required=True, choices=("edit", "verify", "report"))
    command.set_defaults(function=cmd_task_brief)

    command = task_commands.add_parser("unlock", help="clear a stale runner")
    command.add_argument("id")
    command.set_defaults(function=cmd_task_unlock)

    command = commands.add_parser("run", help="run one non-conflicting task wave")
    command.add_argument("ids", nargs="*")
    command.add_argument("--max-parallel", type=int)
    command.add_argument("--dry-run", action="store_true")
    command.set_defaults(function=cmd_run)

    command = commands.add_parser("status", help="show tasks needing attention")
    command.set_defaults(function=cmd_status)

    command = commands.add_parser("stats", help="show read-only aggregate task statistics")
    command.set_defaults(function=cmd_stats)

    command = commands.add_parser("validate", help="check config and task state")
    command.set_defaults(function=cmd_validate)

    command = commands.add_parser("archive", help="archive done and cancelled tasks")
    command.set_defaults(function=cmd_archive)

    orchestrator = commands.add_parser("orchestrator", help="orchestrator phase briefs")
    orchestrator_commands = orchestrator.add_subparsers(
        dest="orchestrator_command", required=True,
    )
    command = orchestrator_commands.add_parser(
        "brief", help="print a state-derived orchestrator phase brief",
    )
    command.add_argument(
        "--phase", required=True, choices=("start", "plan", "run", "review", "close"),
    )
    command.add_argument("id", nargs="?")
    command.add_argument(
        "--include-log-tail", action="store_true",
        help="append a bounded sanitized log tail (review phase only)",
    )
    command.add_argument(
        "--goal", metavar="TEXT",
        help="set the next-session goal (required for the close phase)",
    )
    command.add_argument(
        "--avoid", metavar="TEXT", action="append", default=[],
        help="add a next-session avoid note (close phase only, repeatable)",
    )
    command.set_defaults(function=cmd_orchestrator_brief)

    hooks = commands.add_parser("hooks", help="configure optional host integrations")
    hook_commands = hooks.add_subparsers(dest="hooks_command", required=True)
    command = hook_commands.add_parser(
        "claude-code", help="print or install Claude Code hook settings",
    )
    command.add_argument("--write", action="store_true")
    command.set_defaults(function=cmd_hooks_claude_code)

    command = commands.add_parser("hook-event", help=argparse.SUPPRESS)
    command.add_argument("name", choices=("session-start", "user-prompt-submit"))
    command.set_defaults(function=cmd_hook_event)

    memory = commands.add_parser("memory", help="manage indexed project memory")
    memory_commands = memory.add_subparsers(dest="memory_command", required=True)

    command = memory_commands.add_parser("index", help="list memory entries")
    command.add_argument("--for", dest="audience", choices=("worker", "orchestrator"))
    command.set_defaults(function=cmd_memory_index)

    command = memory_commands.add_parser("show", help="show one memory entry")
    command.add_argument("id")
    command.set_defaults(function=cmd_memory_show)

    command = memory_commands.add_parser("add", help="add a durable project fact")
    command.add_argument("--for", dest="audience", required=True,
                         choices=("worker", "orchestrator", "both"))
    command.add_argument("summary")
    command.add_argument("body")
    command.set_defaults(function=cmd_memory_add)
    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        args.function(args)
    except (OSError, UnicodeDecodeError, RuntimeError, ValueError, json.JSONDecodeError) as error:
        die(str(error))


if __name__ == "__main__":
    main()

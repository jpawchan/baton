def cmd_task_brief(args):
    relay_dir = require_relay_dir()
    worker_id = os.environ.get("RELAY_TASK_ID")
    worker_attempt = os.environ.get("RELAY_ATTEMPT")
    worker_lease = os.environ.get("RELAY_LEASE")
    if not worker_id or not worker_lease:
        die("task brief is available only inside a leased worker process")
    if worker_id != args.id:
        die("a worker may brief only its assigned task: {}".format(worker_id))
    phase_sequence_requires_briefs = configured_phase_sequence_requires_briefs(
        load_config(relay_dir),
    )
    token = None
    with task_lock(relay_dir, args.id):
        task = load_task(relay_dir, args.id)
        attempt = task.get("attempt", 1)
        if worker_attempt != str(attempt):
            die("worker attempt does not match current task attempt")
        if task.get("runner", {}).get("lease") != worker_lease:
            die("worker lease does not match current task lease")
        if task["status"] != "running":
            die("{} is {}, not running".format(task["id"], task["status"]))
        path = os.path.join(work_dir(relay_dir, task["id"]), "attempt-%d.brief.md" % attempt)
        with open(path, encoding="utf-8") as source:
            stored_brief = source.read()
        _digest, separator, capsule = stored_brief.partition("\n\n")
        if not separator or not capsule.startswith("# Critical Context Capsule"):
            die("current attempt capsule is missing or invalid; rerun the task")
        capsule_digest = "sha256:" + hashlib.sha256(capsule.encode("utf-8")).hexdigest()
        receipts_file = phase_receipts_path(relay_dir, task["id"], attempt)
        receipts = read_phase_receipts(
            receipts_file, task["id"], attempt, worker_lease, capsule_digest,
        )
        if receipts is None:
            receipts = {
                "task_id": task["id"],
                "attempt": attempt,
                "lease": worker_lease,
                "capsule_digest": capsule_digest,
                "phases": {},
            }
        phases = receipts["phases"]
        if phase_sequence_requires_briefs:
            required_phases = {
                "verify": ("edit",),
                "report": ("edit", "verify"),
            }.get(args.phase, ())
            for missing_phase in required_phases:
                if missing_phase not in phases:
                    die(
                        "phase sequence requires {} {} brief; run `relay task brief {} "
                        "--phase {}`".format(
                            "an" if missing_phase == "edit" else "a",
                            missing_phase, task["id"], missing_phase,
                        )
                    )
        recorded_at = now()
        previous = phases.get(args.phase)
        phases[args.phase] = {
            "first_at": previous["first_at"] if previous else recorded_at,
            "last_at": recorded_at,
            "count": previous["count"] + 1 if previous else 1,
        }
        atomic_json(receipts_file, receipts)
        if phase_sequence_requires_briefs and args.phase == "edit":
            with suppress(FileNotFoundError):
                os.unlink(brief_token_path(relay_dir, task["id"]))
        if args.phase == "report":
            import secrets

            token = secrets.token_hex(32)
            atomic_json(brief_token_path(relay_dir, task["id"]), {
                "task_id": task["id"],
                "attempt": attempt,
                "lease": worker_lease,
                "token": token,
            })
    say(capsule)
    say()
    say(PHASE_CHECKLISTS[args.phase])
    if token:
        say("Brief token: " + token)


def read_handoff(relay_dir):
    path = orchestrator_handoff_path(relay_dir)
    if not os.path.exists(path):
        return ""
    if os.path.islink(path) or not os.path.isfile(path):
        die("orchestrator handoff must be a regular file")
    with open(path, encoding="utf-8") as source:
        return source.read()[:8000]


def handoff_field(content, name, default=""):
    match = re.search(r"^{}:[ \t]*(.*)$".format(re.escape(name)), content, re.MULTILINE)
    return match.group(1).strip() if match else default


def handoff_done_ids(content):
    match = re.search(r"^done:[ \t]*\n((?:^- .*(?:\n|$))*)", content, re.MULTILINE)
    if not match:
        return set()
    return {
        line[2:].split(":", 1)[0].strip()
        for line in match.group(1).splitlines()
        if line.startswith("- ") and ":" in line
    }


def limited_lines(values, limit=8):
    rendered = [str(value).replace("\n", " ")[:240] for value in values]
    if len(rendered) > limit:
        rendered = rendered[:limit] + ["+{} more".format(len(rendered) - limit)]
    return rendered or ["(none)"]



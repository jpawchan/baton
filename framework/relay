def cmd_task_finish(args):
    relay_dir = require_relay_dir()
    worker_id = os.environ.get("RELAY_TASK_ID")
    worker_attempt = os.environ.get("RELAY_ATTEMPT")
    worker_lease = os.environ.get("RELAY_LEASE")
    if not worker_id or not worker_lease:
        die("task finish is available only inside a leased worker process")
    if worker_id != args.id:
        die("a worker may finish only its assigned task: {}".format(worker_id))
    config = load_config(relay_dir)
    finish_requires_brief = configured_finish_requires_brief(config)
    report_requires_sections = configured_report_requires_sections(config)
    with task_lock(relay_dir, args.id):
        task = load_task(relay_dir, args.id)
        attempt = task.get("attempt", 1)
        if worker_attempt != str(attempt):
            die("worker attempt does not match current task attempt")
        if task.get("runner", {}).get("lease") != worker_lease:
            die("worker lease does not match current task lease")
        if task["status"] != "running":
            die("{} is {}, not running".format(task["id"], task["status"]))
        token_path = brief_token_path(relay_dir, task["id"])
        if finish_requires_brief:
            stored = None
            if os.path.isfile(token_path):
                try:
                    stored = read_json(token_path)
                except (OSError, UnicodeDecodeError, json.JSONDecodeError):
                    stored = None
            if (
                    not args.brief
                    or not isinstance(stored, dict)
                    or stored.get("task_id") != task["id"]
                    or stored.get("attempt") != attempt
                    or stored.get("lease") != worker_lease
                    or stored.get("token") != args.brief):
                die(
                    "a fresh report-phase brief token is required; run `relay task brief {} "
                    "--phase report`, then pass its token as `--brief TOKEN`".format(
                        task["id"],
                    )
                )
        report = report_path(relay_dir, task["id"], attempt)
        if args.status == "needs_review":
            if report_requires_sections:
                report_text, read_problem = read_report_for_section_gate(report)
                problems = (
                    [read_problem] if read_problem
                    else report_section_problems(report_text, args.status)
                )
                if problems:
                    die(
                        "report rejected: {}; fix the report to match the worker.md template, "
                        "then rerun `task finish` with the same `--brief` token".format(
                            "; ".join(problems),
                        )
                    )
            elif not report_is_ready(report):
                die("write a non-empty regular report before requesting review")
        path = result_path(relay_dir, task["id"], attempt)
        if os.path.exists(path):
            die("final status was already submitted for this attempt")
        try:
            changed_paths = normalize_changed_paths(args.changed)
        except ValueError as error:
            die(str(error))
        atomic_json(path, {
            "status": args.status,
            "note": args.note or "",
            "at": now(),
            "lease": worker_lease,
            "changed_paths": changed_paths,
        })
        if finish_requires_brief:
            os.unlink(token_path)
    say("{} submitted {}".format(task["id"], args.status))



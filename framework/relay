def bounded_ids(tasks, statuses, limit=4):
    ids = [task["id"] for task in tasks if task.get("status") in statuses]
    if len(ids) > limit:
        return ids[:limit] + ["+{} more".format(len(ids) - limit)]
    return ids


def decision_question(task):
    latest = latest_worker_exit(task)
    if latest.get("status") == "needs_decision":
        note = task.get("last_note")
        if isinstance(note, str) and note:
            return note
    for entry in reversed(task.get("history", [])):
        if entry.get("event") == "worker_exited" and entry.get("status") == "needs_decision":
            note = entry.get("note")
            return note if isinstance(note, str) and note else ""
    return ""


def render_next_actions(relay_dir):
    tasks = load_all_tasks(relay_dir)
    reviews = [task for task in tasks if task.get("status") == "needs_review"]
    decisions = [task for task in tasks if task.get("status") == "needs_decision"]
    lines = ["Next actions:"]

    review_count = len(reviews)
    decision_count = len(decisions)
    review_shown = decision_shown = 0
    for possible_reviews in range(min(review_count, 5), -1, -1):
        if review_count and not possible_reviews:
            continue
        for possible_decisions in range(min(decision_count, 5), -1, -1):
            if decision_count and not possible_decisions:
                continue
            content_lines = (
                possible_reviews + possible_decisions
                + (possible_reviews < review_count)
                + (possible_decisions < decision_count)
            )
            if content_lines <= 5:
                review_shown = possible_reviews
                decision_shown = possible_decisions
                break
        else:
            continue
        break

    for task in reviews[:review_shown]:
        path = report_path(relay_dir, task["id"], task.get("attempt", 1))
        lines.append("- review {}: {}".format(
            task["id"], os.path.relpath(path, project_root(relay_dir)),
        ))
    if review_shown < review_count:
        lines.append("- review: +{} more".format(review_count - review_shown))
    for task in decisions[:decision_shown]:
        question = flatten_bounded_text(decision_question(task), 160)
        line = "- decide " + task["id"]
        if question:
            line += ": worker question: " + question
        lines.append(line)
    if decision_shown < decision_count:
        lines.append("- decide: +{} more".format(decision_count - decision_shown))
    if not reviews and not decisions:
        if any(task.get("status") == "queued" for task in tasks):
            lines.append("- run: relay orchestrator brief --phase run")
            lines.append("- then: relay run")
        elif not tasks:
            lines.append("- create: relay orchestrator brief --phase plan")
            lines.append("- then: relay task create --title TITLE")
        else:
            lines.append("- no queued, needs_review, or needs_decision tasks")
    return "\n".join(lines)


def say_next_actions(relay_dir):
    say(render_next_actions(relay_dir))


def cmd_task_show(args):
    relay_dir = require_relay_dir()
    task = load_task(relay_dir, args.id, include_archive=True)
    say(json.dumps(task, indent=2))
    say_next_actions(relay_dir)


def cmd_task_capsule(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    active_path = task_json_path(relay_dir, args.id)
    if not os.path.exists(active_path):
        archived_path = os.path.join(archive_dir(relay_dir), args.id + ".json")
        if os.path.exists(archived_path):
            die("{} is archived; capsule preview is available only for active tasks".format(
                args.id,
            ))
    task = load_task(relay_dir, args.id)
    maximum = configured_capsule_max_chars(load_config(relay_dir))
    attempt = task.get("attempt", 1)
    if task.get("status") == "running":
        path = os.path.join(work_dir(relay_dir, task["id"]), "attempt-%d.brief.md" % attempt)
        with open(path, encoding="utf-8") as source:
            stored_brief = source.read()
        _digest, separator, capsule = stored_brief.partition("\n\n")
        if not separator or not capsule.startswith("# Critical Context Capsule"):
            die("current attempt capsule is missing or invalid; rerun the task")
        try:
            result = stored_context_capsule_components(capsule, maximum)
        except ValueError:
            die("current attempt capsule is missing or invalid; rerun the task")
        source_label = "launch (attempt {})".format(attempt)
    else:
        _, memory_text = read_memory(relay_dir)
        memory_entries = memory_index_entries(memory_text)
        with open(task_md_path(relay_dir, task["id"]), encoding="utf-8") as source:
            result = context_capsule_components(
                task, source.read(), memory_entries, maximum,
            )
        capsule = result["text"]
        source_label = "current spec (prospective)"

    digest = hashlib.sha256(capsule.encode("utf-8")).hexdigest()
    if args.raw:
        if result["overflow"]:
            print("error: " + capsule_budget_error(task["id"], result), file=sys.stderr)
            raise SystemExit(1)
        sys.stdout.buffer.write(capsule.encode("utf-8"))
        sys.stdout.buffer.flush()
        return

    say(capsule)
    say()
    say("Capsule diagnostics:")
    if result["overflow"]:
        budget_detail = "{} chars overflow".format(result["overflow"])
    else:
        budget_detail = "{} chars headroom".format(result["headroom"])
    say("Capsule: {} of {} chars ({})".format(
        result["chars"], result["maximum"], budget_detail,
    ))
    say("Sections:")
    for label, count in result["section_chars"]:
        say("- {}: {} chars".format(label, count))
    say("Digest: sha256:" + digest)
    say("Source: " + source_label)
    if result["overflow"]:
        print("error: " + capsule_budget_error(task["id"], result), file=sys.stderr)
        raise SystemExit(1)


def append_md_section(relay_dir, task_id, section, text):
    path = task_md_path(relay_dir, task_id)
    if not os.path.exists(path):
        return
    with open(path, encoding="utf-8") as source:
        content = source.read()
    marker = "## " + section
    if marker in content:
        index = content.index(marker) + len(marker)
        newline = content.find("\n", index)
        if newline == -1:
            content += "\n" + text.rstrip() + "\n"
        else:
            newline += 1
            content = content[:newline] + text.rstrip() + "\n" + content[newline:]
    else:
        content = content.rstrip() + "\n\n" + marker + "\n" + text.rstrip() + "\n"
    atomic_write(path, content)


def ensure_not_live(task):
    runner = task.get("runner")
    if runner and pid_alive(runner.get("pid")):
        die("{} still has a live worker".format(task["id"]))


def cmd_task_accept(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    accept_requires_brief = configured_accept_requires_brief(load_config(relay_dir))
    with task_lock(relay_dir, args.id):
        task = load_task(relay_dir, args.id)
        ensure_not_live(task)
        if task.get("scope_violations"):
            die("{} has unresolved scope violations".format(task["id"]))
        if task["status"] != "needs_review":
            die("{} is {}, not needs_review".format(task["id"], task["status"]))
        token_path = review_token_path(relay_dir, task["id"])
        if accept_requires_brief:
            stored = None
            if os.path.isfile(token_path):
                try:
                    stored = read_json(token_path)
                except (OSError, UnicodeDecodeError, json.JSONDecodeError):
                    stored = None
            if (
                    not args.brief
                    or not isinstance(stored, dict)
                    or stored.get("task_id") != task["id"]
                    or stored.get("attempt") != task.get("attempt", 1)
                    or stored.get("token") != args.brief):
                die(
                    "a fresh review-phase brief token is required; run `relay "
                    "orchestrator brief --phase review {}`, then pass its token as "
                    "`--brief TOKEN`".format(task["id"])
                )
            try:
                capsule, _capsule_drifted, _compile_warning = displayed_review_capsule(
                    relay_dir, task,
                )
                current_manifest = build_review_evidence_manifest(relay_dir, task, capsule)
            except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError):
                die("review evidence changed; run a fresh review brief")
            stored_manifest = dict(stored)
            stored_manifest.pop("token", None)
            if current_manifest != stored_manifest:
                die("review evidence changed; run a fresh review brief")
        task["status"] = "done"
        record(task, "accepted", note=args.note or "")
        save_task(relay_dir, task)
        if accept_requires_brief:
            os.unlink(token_path)
    say("{} accepted".format(task["id"]))


def cmd_task_return(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    with task_lock(relay_dir, args.id):
        task = load_task(relay_dir, args.id)
        ensure_not_live(task)
        if task["status"] not in WORKER_FINAL:
            die("{} is {}; it cannot be returned".format(task["id"], task["status"]))
        violations = task.get("scope_violations", [])
        if violations:
            baseline = task.get("scope_baseline")
            if not baseline:
                die("scope violation baseline is missing; run relay validate")
            root = project_root(relay_dir)
            require_git_root(root)
            current_tree = git_snapshot(root)
            changed = set(git_changed_paths(root, baseline, current_tree))
            unresolved = [path for path in violations if path in changed]
            if unresolved:
                die("restore scope-violating paths before returning: " + ", ".join(unresolved))
        previous_attempt = task.get("attempt", 1)
        task["status"] = "queued"
        task["attempt"] = previous_attempt + 1
        task.pop("runner", None)
        task.pop("scope_violations", None)
        task.pop("scope_baseline", None)
        task.pop("last_note", None)
        record(task, "returned", reason=args.reason)
        save_task(relay_dir, task)
        invalidate_review_token(relay_dir, task["id"])
        append_md_section(
            relay_dir, task["id"], "Review feedback",
            "- attempt %d: %s" % (previous_attempt, args.reason),
        )
    say("%s returned for attempt %d" % (task["id"], task["attempt"]))



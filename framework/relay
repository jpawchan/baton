def cmd_status(args):
    relay_dir = require_relay_dir()
    tasks = load_all_tasks(relay_dir)
    counts: dict[str, int] = {}
    for task in tasks:
        counts[task["status"]] = counts.get(task["status"], 0) + 1
    say("tasks: " + (", ".join("%s=%d" % item for item in sorted(counts.items())) or "none"))
    for task in tasks:

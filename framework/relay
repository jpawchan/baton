def read_phase_receipts(path, task_id=None, attempt=None, lease=None, capsule_digest=None):
    """Read one bounded receipt record, returning None for any malformed shape."""
    try:
        value = read_json(path)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return None
    if not isinstance(value, dict) or set(value) != {
            "task_id", "attempt", "lease", "capsule_digest", "phases"}:
        return None
    if (
            not isinstance(value.get("task_id"), str)
            or isinstance(value.get("attempt"), bool)
            or not isinstance(value.get("attempt"), int)
            or value["attempt"] < 1
            or not isinstance(value.get("lease"), str)
            or not value["lease"]
            or not isinstance(value.get("capsule_digest"), str)
            or not re.fullmatch(r"sha256:[0-9a-f]{64}", value["capsule_digest"])
            or not isinstance(value.get("phases"), dict)):
        return None
    if task_id is not None and value["task_id"] != task_id:
        return None
    if attempt is not None and value["attempt"] != attempt:
        return None
    if lease is not None and value["lease"] != lease:
        return None
    if capsule_digest is not None and value["capsule_digest"] != capsule_digest:
        return None
    phases = value["phases"]
    if not set(phases).issubset(PHASE_CHECKLISTS):
        return None
    for receipt in phases.values():
        if not isinstance(receipt, dict) or set(receipt) != {"first_at", "last_at", "count"}:
            return None
        if (
                not isinstance(receipt.get("first_at"), str)
                or not receipt["first_at"]
                or not isinstance(receipt.get("last_at"), str)
                or not receipt["last_at"]
                or isinstance(receipt.get("count"), bool)
                or not isinstance(receipt.get("count"), int)
                or receipt["count"] < 1):
            return None
    return value



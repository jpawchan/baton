def sha256_regular_file(path):
    """Return a streaming SHA-256 hex digest for a non-symlink regular file."""
    if os.path.islink(path):
        raise OSError("not a regular file: {}".format(path))
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    descriptor = os.open(path, flags)
    try:
        if not stat.S_ISREG(os.fstat(descriptor).st_mode):
            raise OSError("not a regular file: {}".format(path))
        digest = hashlib.sha256()
        with os.fdopen(descriptor, "rb") as source:
            descriptor = None
            while True:
                chunk = source.read(1024 * 1024)
                if not chunk:
                    break
                digest.update(chunk)
        return digest.hexdigest()
    finally:
        if descriptor is not None:
            os.close(descriptor)


def build_review_evidence_manifest(relay_dir, task, capsule):
    """Build the immutable evidence description used by the review accept gate."""
    attempt = task.get("attempt", 1)
    report = report_path(relay_dir, task["id"], attempt)
    result_file = result_path(relay_dir, task["id"], attempt)
    diff = diff_path(relay_dir, task["id"], attempt)
    hashes = {
        "report": sha256_regular_file(report),
        "result": sha256_regular_file(result_file),
        "diff": sha256_regular_file(diff),
    }
    result = read_json(result_file)
    if sha256_regular_file(result_file) != hashes["result"]:
        raise OSError("review result changed while its manifest was built")
    declared = worker_changed_paths(result.get("changed_paths"))
    if declared is None:
        raise ValueError("review result changed_paths are missing or invalid")
    worker_exit = latest_worker_exit(task)
    observed = worker_exit.get("observed_paths", [])
    if not isinstance(observed, list) or not all(isinstance(path, str) for path in observed):
        raise ValueError("review observed changed paths are invalid")
    return {
        "task_id": task["id"],
        "attempt": attempt,
        "evidence": {
            "capsule": "sha256:" + hashlib.sha256(capsule.encode("utf-8")).hexdigest(),
            "report": "sha256:" + hashes["report"],
            "result": "sha256:" + hashes["result"],
            "diff": "sha256:" + hashes["diff"],
            "declared": sorted(declared),
            "observed": sorted(observed),
        },
    }



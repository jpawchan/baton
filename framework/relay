def latest_worker_exit(task):
    for entry in reversed(task.get("history", [])):
        if entry.get("event") == "worker_exited":
            return entry
    return {}


def compile_current_task_capsule(relay_dir, task):
    config = load_config(relay_dir)
    _, memory_text = read_memory(relay_dir)
    memory_entries = memory_index_entries(memory_text)
    with open(task_md_path(relay_dir, task["id"]), encoding="utf-8") as source:
        return compile_context_capsule(
            task, source.read(), memory_entries,
            configured_capsule_max_chars(config),
        )


def displayed_review_capsule(relay_dir, task, check_fresh=False):
    """Select the capsule review displays, optionally checking current-input drift."""
    attempt = task.get("attempt", 1)
    brief_file = os.path.join(
        work_dir(relay_dir, task["id"]), "attempt-%d.brief.md" % attempt,
    )
    if os.path.lexists(brief_file):
        if os.path.islink(brief_file) or not os.path.isfile(brief_file):
            raise OSError("current attempt capsule is missing or invalid; rerun the task")
        with open(brief_file, encoding="utf-8") as source:
            stored_brief = source.read()
        _digest, separator, stored_capsule = stored_brief.partition("\n\n")
        if not separator or not stored_capsule.startswith("# Critical Context Capsule"):
            raise ValueError("current attempt capsule is missing or invalid; rerun the task")
        if not check_fresh:
            return stored_capsule, False, None
        try:
            fresh_capsule = compile_current_task_capsule(relay_dir, task)
        except (OSError, UnicodeDecodeError, ValueError, json.JSONDecodeError) as error:
            error_text = " ".join(str(error).split())[:400]
            warning = (
                "capsule inputs could not be compiled since launch; showing launch "
                "capsule: " + error_text
            )
            return stored_capsule, False, warning
        return stored_capsule, fresh_capsule != stored_capsule, None
    return compile_current_task_capsule(relay_dir, task), False, None


def orchestrator_review_brief(relay_dir, task_id, include_log_tail=False):
    import secrets

    with task_lock(relay_dir, task_id):
        task = load_task(relay_dir, task_id)
        if task.get("status") != "needs_review":
            die("{} is {}, not needs_review".format(task["id"], task.get("status")))
        attempt = task.get("attempt", 1)
        capsule, capsule_drifted, compile_warning = displayed_review_capsule(
            relay_dir, task, check_fresh=True,
        )
        manifest = build_review_evidence_manifest(relay_dir, task, capsule)
        worker_exit = latest_worker_exit(task)
        diff_summary = attempt_diff_summary(
            diff_path(relay_dir, task["id"], attempt),
            manifest["evidence"]["observed"],
        )
        prior_artifacts = []
        omitted_prior_attempts = 0
        for prior_attempt in range(attempt - 1, 0, -1):
            paths = []
            for name, artifact in (
                    ("report", report_path(relay_dir, task["id"], prior_attempt)),
                    ("diff", diff_path(relay_dir, task["id"], prior_attempt))):
                if os.path.isfile(artifact) and not os.path.islink(artifact):
                    paths.append((name, artifact))
            if paths:
                if len(prior_artifacts) < 3:
                    prior_artifacts.append((prior_attempt, paths))
                else:
                    omitted_prior_attempts += 1
        log = os.path.join(work_dir(relay_dir, task["id"]), "attempt-%d.log" % attempt)
        log_tail = untrusted_log_tail_block(log) if include_log_tail else None
        receipts = read_phase_receipts(
            phase_receipts_path(relay_dir, task["id"], attempt),
            task["id"], attempt,
        )
        token = secrets.token_hex(32)
        token_record = dict(manifest)
        token_record["token"] = token
        atomic_json(review_token_path(relay_dir, task["id"]), token_record)
    root = project_root(relay_dir)
    report = report_path(relay_dir, task["id"], attempt)
    result_file = result_path(relay_dir, task["id"], attempt)
    diff = diff_path(relay_dir, task["id"], attempt)
    evidence = manifest["evidence"]
    say(capsule)
    if compile_warning:
        say("\nWARNING: " + compile_warning)
    elif capsule_drifted:
        say(
            "\nWARNING: capsule inputs drifted since launch (spec or memory changed); "
            "showing launch capsule"
        )
    if task.get("warning"):
        say("\nWARNING: Worker exited with code {} after submission; inspect log: {}".format(
            worker_exit.get("exit_code"), os.path.relpath(log, root),
        ))
    say("\nReview artifacts:")
    say("- Report: {} (sha256:{})".format(
        os.path.relpath(report, root), evidence["report"][7:19],
    ))
    say("- Result: {} (sha256:{})".format(
        os.path.relpath(result_file, root), evidence["result"][7:19],
    ))
    say("- Diff: {} (sha256:{})".format(
        os.path.relpath(diff, root), evidence["diff"][7:19],
    ))
    declared = evidence["declared"]
    observed = evidence["observed"]
    say("- Declared changed paths: " + (
        ", ".join(declared) if declared else "(none)"
    ))
    say("- Observed changed paths: " + (
        ", ".join(observed) if observed else "(none recorded)"
    ))
    if receipts is None:
        say("Phase briefs: none recorded")
    else:
        say("Phase briefs: " + " ".join(
            "{}={}".format(phase, receipts["phases"].get(phase, {}).get("count", 0))
            for phase in ("edit", "verify", "report")
        ))
    if not diff_summary["files"]:
        say("Diff stat: no changes")
    else:
        say("Diff stat: {} files, +{} -{}".format(
            len(diff_summary["files"]),
            diff_summary["added"], diff_summary["removed"],
        ))
        stat_lines = [
            "{}: +{} -{} {}".format(
                item["path"], item["added"], item["removed"], item["label"],
            )
            for item in diff_summary["files"]
        ]
        for line in limited_lines(stat_lines, limit=10):
            say("- " + line)
    if prior_artifacts:
        say("Prior attempt artifacts (most recent first):")
        for prior_attempt, paths in prior_artifacts:
            for name, artifact in paths:
                say("- attempt {} {}: {}".format(
                    prior_attempt, name, os.path.relpath(artifact, root),
                ))
        if omitted_prior_attempts:
            say("- +{} older attempt{}".format(
                omitted_prior_attempts,
                "s" if omitted_prior_attempts != 1 else "",
            ))
    if log_tail is not None:
        say("\n" + log_tail)
    say("Review checklist:")
    say("- Compare the report, diff, and declared/observed paths to the criteria.")
    say("- Verify the reported checks and inspect risky full files when needed.")
    say("- Accept with this token, return with a concrete reason, or decide a question.")
    say("Review token: " + token)


def orchestrator_run_brief(relay_dir, tasks):
    config = load_config(relay_dir)
    max_parallel, _timeout = configured_limits(config)
    archived = load_archived_tasks(relay_dir)
    busy_scopes = [task.get("scope", []) for task in tasks
                   if task.get("status") == "running"]
    wave, skipped = pick_wave(tasks, archived, [], max_parallel, busy_scopes)
    say("Would run: " + (", ".join(task["id"] for task in wave) or "(nothing)"))
    cautions = [(task_id, reason) for task_id, reason in skipped
                if "scope conflicts" in reason or "waiting on" in reason]
    say("Cautions:")
    for task_id, reason in cautions[:10]:
        say("- {}: {}".format(task_id, reason))
    if len(cautions) > 10:
        say("- +{} more".format(len(cautions) - 10))
    if not cautions:
        say("- none")


def orchestrator_close_brief(relay_dir, tasks, goal, avoid_notes):
    with file_lock(lock_path(relay_dir, "orchestrator-handoff")):
        previous = read_handoff(relay_dir)
        previous_at = handoff_field(previous, "generated_at")
        previous_done = handoff_done_ids(previous)
        done = {}
        decisions = []
        for task in tasks + load_archived_tasks(relay_dir):
            for entry in task.get("history", []):
                if entry.get("event") == "accepted" and (
                        not previous_at or entry.get("at", "") >= previous_at):
                    if task["id"] not in previous_done:
                        done[task["id"]] = "{}: {}".format(
                            task["id"], task.get("title", ""),
                        )
                if entry.get("event") == "decided":
                    decisions.append((entry.get("at", ""), "{}: {}".format(
                        task["id"], entry.get("answer", ""),
                    )))
        decisions = [text for _at, text in sorted(decisions, reverse=True)[:8]]
        next_ids = [task["id"] for task in tasks
                    if task.get("status") in {"queued", "needs_review"}]
        unresolved = [task["id"] for task in tasks
                      if task.get("status") == "needs_decision"]
        sections = [
            "# Orchestrator handoff", "generated_at: " + now(),
            "consumed_at: (not yet)", "goal: " + goal,
        ]
        for name, values in (
                ("done", sorted(done.values())), ("decisions", decisions),
                ("next", next_ids), ("unresolved", unresolved),
                ("avoid", avoid_notes or ["(fill in)"])):
            sections.append(name + ":")
            sections.extend("- " + line for line in limited_lines(values))
        content = "\n".join(sections) + "\n"
        atomic_write(orchestrator_handoff_path(relay_dir), content)
    say(content.rstrip())
    say("Start a fresh session, then run: relay orchestrator brief --phase start")


def cmd_orchestrator_brief(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    tasks = load_all_tasks(relay_dir)
    if args.include_log_tail and args.phase != "review":
        die("--include-log-tail is valid only for the review phase")
    if args.goal is not None and args.phase != "close":
        die("`--goal` is valid only for the close phase")
    if args.avoid and args.phase != "close":
        die("`--avoid` is valid only for the close phase")
    if args.phase == "close":
        if len(args.avoid) > 5:
            die("at most 5 `--avoid` notes are allowed; consolidate them")
        goal = flatten_bounded_text(args.goal, 200)
        if not goal:
            die("`--phase close` requires a nonblank goal; add `--goal TEXT`")
        avoid_notes = [
            note for note in (
                flatten_bounded_text(value, 200) for value in args.avoid
            ) if note
        ]
    if args.phase == "review":
        if not args.id:
            die("review phase requires a task id")
        orchestrator_review_brief(relay_dir, args.id, args.include_log_tail)
    elif args.id:
        die("a task id is valid only for the review phase")
    elif args.phase == "start":
        orchestrator_start_brief(relay_dir, tasks)
    elif args.phase == "plan":
        orchestrator_plan_brief(tasks)
    elif args.phase == "run":
        orchestrator_run_brief(relay_dir, tasks)
    else:
        orchestrator_close_brief(relay_dir, tasks, goal, avoid_notes)


def claude_code_hook_fragment():
    return {
        "hooks": {
            event: [{"hooks": [{"type": "command", "command": command}]}]
            for event, command in CLAUDE_HOOK_COMMANDS.items()
        },
    }


def claude_hook_command_is_registered(entries, command):
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        hooks = entry.get("hooks")
        if not isinstance(hooks, list):
            continue
        if any(isinstance(hook, dict) and hook.get("command") == command for hook in hooks):
            return True
    return False


def cmd_hooks_claude_code(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    fragment = claude_code_hook_fragment()
    if not args.write:
        say(json.dumps(fragment, indent=2))
        say("Merge this fragment into .claude/settings.json, or rerun with --write.")
        return

    root = project_root(relay_dir)
    claude_dir = os.path.join(root, ".claude")
    settings_path = os.path.join(claude_dir, "settings.json")
    if os.path.lexists(claude_dir) and (
            os.path.islink(claude_dir) or not os.path.isdir(claude_dir)):
        die(".claude must be a real directory inside the project")
    if os.path.lexists(settings_path) and (
            os.path.islink(settings_path) or not os.path.isfile(settings_path)):
        die(".claude/settings.json must be a regular file")
    if os.path.exists(settings_path):
        try:
            with open(settings_path, encoding="utf-8") as source:
                settings = json.load(source)
        except (OSError, UnicodeDecodeError, json.JSONDecodeError) as error:
            die("cannot parse .claude/settings.json: {}".format(error))
        if not isinstance(settings, dict):
            die(".claude/settings.json must contain a JSON object")
    else:
        settings = {}

    hooks = settings.get("hooks")
    if hooks is None:
        hooks = {}
        settings["hooks"] = hooks
    if not isinstance(hooks, dict):
        die('.claude/settings.json "hooks" must be a JSON object')
    for event, command in CLAUDE_HOOK_COMMANDS.items():
        entries = hooks.get(event)
        if entries is None:
            entries = []
            hooks[event] = entries
        if not isinstance(entries, list):
            die('.claude/settings.json hooks.{} must be a JSON array'.format(event))
        if not claude_hook_command_is_registered(entries, command):
            entries.append(fragment["hooks"][event][0])
    atomic_json(settings_path, settings)
    say("updated .claude/settings.json")


def cap_hook_output(text, maximum=HOOK_OUTPUT_MAX_CHARS):
    if len(text) <= maximum:
        return text
    trailing_newline = "\n" if text.endswith("\n") else ""
    lines = text.rstrip("\n").split("\n")
    if len(lines) < 2:
        return ""
    first, last = lines[0], lines[-1]
    suffix = "\n(truncated)\n" + last + trailing_newline
    if len(first) + len(suffix) > maximum:
        return ""
    available = maximum - len(first) - len(suffix)
    middle = "\n".join(lines[1:-1])
    prefix = middle[:max(0, available - 1)].rstrip("\n")
    return first + (("\n" + prefix) if prefix else "") + suffix


def claude_user_prompt_output(context):
    def encode(value):
        return json.dumps({
            "hookSpecificOutput": {
                "hookEventName": "UserPromptSubmit",
                "additionalContext": value,
            },
        }, separators=(",", ":")) + "\n"

    output = encode(context)
    if len(output) <= HOOK_OUTPUT_MAX_CHARS:
        return output
    low, high = 0, len(context) - 1
    best = ""
    while low <= high:
        middle = (low + high) // 2
        capped = cap_hook_output(context, middle)
        if not capped and context:
            low = middle + 1
            continue
        candidate = encode(capped)
        if len(candidate) <= HOOK_OUTPUT_MAX_CHARS:
            best = candidate
            low = middle + 1
        else:
            high = middle - 1
    return best


def cmd_hook_event(args):
    require_orchestrator()
    try:
        raw_input = sys.stdin.read()
        if raw_input:

                die("{} is not running".format(task["id"]))
            pid = task.get("runner", {}).get("pid")
            if pid_alive(pid):
                die("worker pid {} is still alive; stop it before unlocking".format(pid))
            task["status"] = "failed"
            task.pop("runner", None)
            task["last_note"] = "stale_runner"
            record(task, "unlocked", reason="stale_runner")
            save_task(relay_dir, task)
    say("{} marked failed; return it to retry".format(task["id"]))


# Git snapshots and diffs

def git_run(root, *arguments, env=None, text=True):
    try:
        return subprocess.run(
            ["git", "-C", root, *arguments], env=env,
            capture_output=True, text=text,
        )
    except FileNotFoundError:
        die("Git is required")


def is_git_repo(root):
    result = git_run(root, "rev-parse", "--is-inside-work-tree")
    return result.returncode == 0 and result.stdout.strip() == "true"


def gitlink_paths(output):
    paths = []
    for entry in output.split("\0"):
        if not entry or "\t" not in entry:
            continue
        metadata, path = entry.split("\t", 1)
        if metadata.split()[0] == "160000":
            paths.append(path)
    return paths


def git_submodule_paths(root):
    paths = set(gitlink_paths(git_checked(root, "ls-files", "--stage", "-z")))
    head = git_run(root, "ls-tree", "-r", "-z", "HEAD")
    if head.returncode == 0:
        paths.update(gitlink_paths(head.stdout))
    return sorted(paths)


def require_git_root(root):
    if not is_git_repo(root):
        die("Attention Relay requires a Git repository")
    top_level = git_checked(root, "rev-parse", "--show-toplevel").strip()
    if os.path.realpath(root) != os.path.realpath(top_level):
        die("Attention Relay must run from the Git worktree root: {}".format(top_level))
    submodules = git_submodule_paths(root)
    if submodules:
        die("tracked Git submodules are unsupported: " + ", ".join(submodules))


def git_checked(root, *arguments, env=None, text=True):
    result = git_run(root, *arguments, env=env, text=text)
    if result.returncode:
        stderr = result.stderr if text else os.fsdecode(result.stderr)
        raise RuntimeError("git {} failed: {}".format(arguments[0], stderr.strip()))
    return result.stdout


def git_snapshot(root):
    fd, index_path = tempfile.mkstemp(prefix="attention-relay-index-")
    os.close(fd)
    os.unlink(index_path)
    env = dict(os.environ, GIT_INDEX_FILE=index_path)
    try:
        head = git_run(root, "rev-parse", "--verify", "HEAD")
        if head.returncode == 0:
            git_checked(root, "read-tree", "HEAD", env=env)
        else:
            git_checked(root, "read-tree", "--empty", env=env)
        git_checked(root, "add", "-A", "--", ".", env=env)
        tree = git_checked(root, "write-tree", env=env).strip()
        links = gitlink_paths(git_checked(root, "ls-tree", "-r", "-z", tree))
        if links:
            raise RuntimeError("Git submodules are unsupported: " + ", ".join(links))
        return tree
    finally:
        with suppress(FileNotFoundError):
            os.unlink(index_path)


def git_changed_paths(root, before_tree, after_tree):
    output = git_checked(
        root, "diff", "--name-only", "-z", "--no-renames",
        before_tree, after_tree, text=False,
    )
    return sorted(os.fsdecode(item) for item in output.split(b"\0") if item)


def git_paths_diff(root, before_tree, after_tree, paths):
    if not paths:
        return ""
    pathspecs = [":(literal)" + path for path in paths]
    return git_checked(
        root, "diff", "--binary", "--no-renames", before_tree, after_tree,
        "--", *pathspecs,
    )


def git_tree_diff(root, before_tree, after_tree, scopes, changed_paths):
    paths = [path for path in changed_paths if path_in_scopes(path, scopes)]
    return git_paths_diff(root, before_tree, after_tree, paths)


# Runner

def pid_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except (OSError, TypeError, ValueError):
        return False


def terminate_process_groups(pids, grace=0.5):
    groups = []
    for pid in pids:
        if not pid:
            continue
        try:
            group = int(pid)
            os.killpg(group, signal.SIGTERM)
            groups.append(group)
        except (OSError, TypeError, ValueError):
            continue
    deadline = time.monotonic() + grace
    while groups and time.monotonic() < deadline:
        alive = []
        for group in groups:
            try:
                os.killpg(group, 0)
                alive.append(group)
            except OSError:
                pass
        groups = alive
        if groups:
            time.sleep(min(0.02, max(0, deadline - time.monotonic())))
    for group in groups:
        with suppress(OSError):
            os.killpg(group, signal.SIGKILL)


def terminate_process_group(pid, grace=0.5):
    terminate_process_groups([pid], grace)


WORKER_PROMPT = """Attention Relay worker: {id}, attempt {attempt}
Project: {root}
Scope: {scope}

Read and follow:
- {relay_dir}/worker.md
- {relay_dir}/tasks/{id}.md{previous}

Immediately before writing the report, run:
python3 {relay_dir}/relay task brief {id} --phase report
Write the report to {report}, then finish with its Brief token and every exact changed path:
python3 {relay_dir}/relay task finish {id} --status needs_review --brief TOKEN [--changed PATH ...]
Use needs_decision, blocked, or failed instead when needed.
Other workers may be active. Run only the targeted checks in the task spec.
"""


def build_prompt(
        relay_dir, task, memory_entries, capsule_max_chars=4000, capsule=None):
    root = project_root(relay_dir)
    relative_relay = os.path.relpath(relay_dir, root)
    attempt = task.get("attempt", 1)
    previous = ""
    if attempt > 1:
        previous = "\n- %s/work/%s/attempt-%d.report.md" % (
            relative_relay, task["id"], attempt - 1,
        )
    if capsule is None:
        with open(task_md_path(relay_dir, task["id"]), encoding="utf-8") as source:
            capsule = compile_context_capsule(
                task, source.read(), memory_entries, capsule_max_chars,
            )
    mechanics = WORKER_PROMPT.format(
        id=task["id"], attempt=attempt, root=root,
        scope=", ".join(task.get("scope", [])) or "whole project",
        relay_dir=relative_relay, previous=previous,
        report=os.path.relpath(report_path(relay_dir, task["id"], attempt), root),
    ).strip()
    return (
        capsule + "\n\n" + mechanics
        + "\n\n## Re-read before acting (same capsule, repeated on purpose)\n\n"
        + capsule
    )


def prepare_worker(relay_dir, config, task, memory_entries):
    root = project_root(relay_dir)
    attempt = task.get("attempt", 1)
    capsule_max_chars = configured_capsule_max_chars(config)
    with open(task_md_path(relay_dir, task["id"]), encoding="utf-8") as source:
        capsule = compile_context_capsule(
            task, source.read(), memory_entries, capsule_max_chars,
        )
    prompt = build_prompt(
        relay_dir, task, memory_entries, capsule_max_chars, capsule=capsule,
    )
    directory = work_dir(relay_dir, task["id"])
    os.makedirs(directory, exist_ok=True)
    prompt_file = os.path.join(directory, "attempt-%d.prompt.md" % attempt)
    atomic_write(prompt_file, prompt)
    digest = hashlib.sha256(capsule.encode("utf-8")).hexdigest()
    brief_file = os.path.join(directory, "attempt-%d.brief.md" % attempt)
    atomic_write(brief_file, "Content digest: sha256:{}\n\n{}".format(digest, capsule))
    result = result_path(relay_dir, task["id"], attempt)
    if os.path.exists(result):
        raise ValueError("result already exists for %s attempt %d" % (task["id"], attempt))
    argv = worker_argv(config, task, prompt, prompt_file, root)
    return {
        "task": task,
        "argv": argv,
        "prompt_file": prompt_file,
        "log_path": os.path.join(directory, "attempt-%d.log" % attempt),
        "capsule_chars": len(capsule),
        "capsule_digest": digest,
    }


def run_one_worker(relay_dir, prepared, timeout_minutes, stop_event):
    task = prepared["task"]
    root = project_root(relay_dir)
    attempt = task.get("attempt", 1)
    environment = dict(
        os.environ,
        RELAY_TASK_ID=task["id"],
        RELAY_ATTEMPT=str(attempt),
        RELAY_LEASE=prepared["lease"],
        RELAY_DIR=relay_dir,
        RELAY_ROOT=root,
    )
    say("[%s] start attempt %d (%s)" % (
        task["id"], attempt, task.get("tier", "default"),
    ))
    process = None
    try:
        if stop_event.is_set():
            return {"interrupted": True, "returncode": None}
        with open(prepared["log_path"], "w", encoding="utf-8") as log:
            process = subprocess.Popen(
                prepared["argv"], cwd=root, env=environment,
                stdout=log, stderr=subprocess.STDOUT,
                start_new_session=True,
            )
            if stop_event.is_set():
                terminate_process_group(process.pid)
                process.wait()
                return {"interrupted": True, "returncode": None}
            with task_lock(relay_dir, task["id"]):
                current = load_task(relay_dir, task["id"])
                runner = current.get("runner", {})
                if (
                        current["status"] != "running"
                        or current.get("attempt", 1) != attempt
                        or runner.get("lease") != prepared["lease"]):
                    terminate_process_group(process.pid)
                    process.wait()
                    return {"error": "task_state_changed", "returncode": None}
                runner["pid"] = process.pid
                runner["started_at"] = now()
                current["runner"] = runner
                save_task(relay_dir, current)
            try:
                returncode = process.wait(
                    timeout=timeout_minutes * 60 if timeout_minutes else None,
                )
            except subprocess.TimeoutExpired:
                terminate_process_group(process.pid)
                process.wait()
                return {"timeout": True, "returncode": None}
        terminate_process_group(process.pid, grace=0.1)
        return {"returncode": returncode}
    except BaseException as error:
        if process and process.poll() is None:
            terminate_process_group(process.pid)
            process.wait()
        return {"error": "{}: {}".format(type(error).__name__, error), "returncode": None}


def pick_wave(tasks, archived_tasks, requested_ids, max_parallel, busy_scopes):
    done = {task["id"] for task in tasks + archived_tasks if task.get("status") == "done"}
    by_id = {task["id"]: task for task in tasks}
    if requested_ids:
        candidates = []
        for task_id in requested_ids:
            if task_id not in by_id:
                die("no such active task: {}".format(task_id))
            candidates.append(by_id[task_id])
    else:
        candidates = [task for task in tasks if task.get("status") == "queued"]
    wave: list[dict] = []
    skipped = []
    leased = list(busy_scopes)
    for task in candidates:
        if task.get("status") != "queued":
            skipped.append((task["id"], "status is {}".format(task.get("status"))))
            continue
        missing = [item for item in task.get("depends_on", []) if item not in done]
        if missing:
            skipped.append((task["id"], "waiting on {}".format(",".join(missing))))
            continue
        if any(scopes_overlap(task.get("scope", []), scope) for scope in leased):
            skipped.append((task["id"], "scope conflicts with another lease"))
            continue
        if len(wave) >= max_parallel:
            skipped.append((task["id"], "max_parallel reached"))
            continue
        wave.append(task)
        leased.append(task.get("scope", []))
    return wave, skipped


def worker_changed_paths(value):
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        return None
    try:
        normalized = normalize_changed_paths(value)
    except ValueError:
        return None
    if normalized != value:
        return None
    return normalized


def finalize_task(
        relay_dir, task, outcome, violations, observed_paths, baseline_tree, lease):
    attempt = task.get("attempt", 1)
    submitted = None
    path = result_path(relay_dir, task["id"], attempt)
    result_exists = os.path.exists(path)
    if result_exists:
        try:
            submitted = read_json(path)
        except (OSError, UnicodeDecodeError, json.JSONDecodeError):
            submitted = None
    with task_lock(relay_dir, task["id"]):
        current = load_task(relay_dir, task["id"])
        runner = current.get("runner", {})
        if (
                current.get("status") != "running"
                or current.get("attempt", 1) != attempt
                or runner.get("lease") != lease):
            say("[{}] stale finalizer ignored".format(task["id"]))
            return False
        current.pop("runner", None)
        note = ""
        warning = ""
        declared_paths = (
            worker_changed_paths(submitted.get("changed_paths"))
            if isinstance(submitted, dict) else None
        )
        if outcome.get("interrupted"):
            status, note = "failed", "orchestrator_interrupted"
        elif outcome.get("timeout"):
            status, note = "failed", "worker_timeout"
        elif outcome.get("error"):
            status, note = "failed", "worker_error: " + outcome["error"]
        elif outcome.get("returncode") != 0 and not result_exists:
            status, note = "failed", "worker_exit_{}".format(outcome.get("returncode"))
        elif (
                not isinstance(submitted, dict)
                or submitted.get("status") not in WORKER_FINAL
                or not isinstance(submitted.get("note"), str)
                or not isinstance(submitted.get("at"), str)
                or submitted.get("lease") != lease
                or declared_paths is None):
            status, note = "failed", "invalid_worker_output"
        elif submitted["status"] == "needs_review" and not report_is_ready(
                report_path(relay_dir, task["id"], attempt)):
            status, note = "failed", "missing_review_report"
        elif violations:
            status, note = "blocked", "scope_violation"
        elif (
                {path.casefold() for path in declared_paths or []}
                != {path.casefold() for path in observed_paths}):
            status, note = "failed", "changed_paths_mismatch"
        else:
            status = submitted["status"]
            note = submitted.get("note", "")
            if outcome.get("returncode") != 0:
                warning = "worker_exit_{}_after_submission".format(
                    outcome.get("returncode"),
                )
        current["status"] = status
        if note:
            current["last_note"] = note
        else:
            current.pop("last_note", None)
        if warning:
            current["warning"] = warning
        else:
            current.pop("warning", None)
        if violations:
            current["scope_violations"] = list(violations)
            current["scope_baseline"] = baseline_tree
        else:
            current.pop("scope_violations", None)
            current.pop("scope_baseline", None)
        if warning:
            record(
                current, "worker_exited", status=status,
                exit_code=outcome.get("returncode"), note=note, warning=warning,
                declared_paths=declared_paths, observed_paths=list(observed_paths),
            )
        else:
            record(
                current, "worker_exited", status=status,
                exit_code=outcome.get("returncode"), note=note,
                declared_paths=declared_paths, observed_paths=list(observed_paths),
            )
        save_task(relay_dir, current)
    say("[{}] {}{}".format(
        task["id"], status, " ({})".format(note) if note else "",
    ))
    return True


def abort_claimed_tasks(relay_dir, context):
    context["stop_event"].set()
    pids = []
    for task_id in context["task_ids"]:
        task = load_task(relay_dir, task_id)
        runner = task.get("runner", {})
        if runner.get("lease") == context["lease"]:
            pids.append(runner.get("pid"))
    terminate_process_groups(pids)
    for task_id in context["task_ids"]:
        with task_lock(relay_dir, task_id):
            task = load_task(relay_dir, task_id)
            runner = task.get("runner", {})
            if task.get("status") != "running" or runner.get("lease") != context["lease"]:
                continue
            task.pop("runner", None)
            task["status"] = "failed"
            task["last_note"] = "orchestrator_interrupted"
            record(task, "worker_exited", status="failed",
                   exit_code=None, note="orchestrator_interrupted")
            save_task(relay_dir, task)


def cmd_run(args):
    require_orchestrator()
    relay_dir = require_relay_dir()
    import secrets

    context = {
        "lease": secrets.token_hex(16),
        "stop_event": threading.Event(),
        "task_ids": [],
    }
    watched = [signal.SIGTERM]
    if hasattr(signal, "SIGHUP"):
        watched.append(signal.SIGHUP)
    previous = {item: signal.getsignal(item) for item in watched}
    for item in watched:
        signal.signal(item, handle_run_signal)
    try:
        if args.dry_run:
            run_wave(args, relay_dir, context)
        else:
            with file_lock(lock_path(relay_dir, "execution")):
                run_wave(args, relay_dir, context)
    except KeyboardInterrupt:
        abort_claimed_tasks(relay_dir, context)
        raise SystemExit(130) from None
    except RunInterrupted as error:
        abort_claimed_tasks(relay_dir, context)
        raise SystemExit(128 + error.signum) from None
    finally:
        for item, handler in previous.items():
            signal.signal(item, handler)
        if not args.dry_run:
            say_next_actions(relay_dir)


def run_wave(args, relay_dir, context):
    from concurrent.futures import ThreadPoolExecutor, as_completed

    root = project_root(relay_dir)
    require_git_root(root)
    config = load_config(relay_dir)
    try:
        max_parallel, timeout_minutes = configured_limits(config, args.max_parallel)
        _, memory_text = read_memory(relay_dir)
        memory_entries = memory_index_entries(memory_text)
    except ValueError as error:
        die(str(error))

    with file_lock(lock_path(relay_dir, "scheduler")):
        tasks = load_all_tasks(relay_dir)
        archived = load_archived_tasks(relay_dir)
        busy_scopes = [task.get("scope", []) for task in tasks
                       if task.get("status") == "running"]
        wave, skipped = pick_wave(tasks, archived, args.ids, max_parallel, busy_scopes)
        if args.dry_run:
            say("would run: %s" % (", ".join(task["id"] for task in wave) or "(nothing)"))
            for task_id, reason in skipped:
                say("  skip {}: {}".format(task_id, reason))
            return
        if not wave:
            say("would run: (nothing)")
            for task_id, reason in skipped:
                say("  skip {}: {}".format(task_id, reason))
            raise SystemExit(0 if not skipped else 1)
        try:
            prepared = [
                prepare_worker(relay_dir, config, task, memory_entries)
                for task in wave
            ]
            for item in prepared:
                item["lease"] = context["lease"]
            before_tree = git_snapshot(root)
        except (OSError, RuntimeError, ValueError) as error:
            die(str(error))
        context["task_ids"] = [task["id"] for task in wave]
        prepared_by_id = {item["task"]["id"]: item for item in prepared}
        for task in wave:
            with task_lock(relay_dir, task["id"]):
                current = load_task(relay_dir, task["id"])
                if current["status"] != "queued":
                    die("{} is no longer queued".format(task["id"]))
                current["status"] = "running"
                current["runner"] = {
                    "pid": None, "started_at": now(), "lease": context["lease"],
                }
                record(current, "launched", attempt=current.get("attempt", 1),
                       lease=context["lease"],
                       capsule_chars=prepared_by_id[task["id"]]["capsule_chars"])
                save_task(relay_dir, current)

    outcomes = {}
    interrupted = False
    interrupted_code = 130
    stop_event = context["stop_event"]
    executor = None
    futures = {}
    try:
        executor = ThreadPoolExecutor(max_workers=len(wave))
        futures = {
            executor.submit(
                run_one_worker, relay_dir, item, timeout_minutes, stop_event,
            ): item["task"]
            for item in prepared
        }
        for future in as_completed(futures):
            outcomes[futures[future]["id"]] = future.result()
    except (KeyboardInterrupt, RunInterrupted) as error:
        interrupted = True
        if isinstance(error, RunInterrupted):
            interrupted_code = 128 + error.signum
        stop_event.set()
        terminate_process_groups([
            load_task(relay_dir, task["id"]).get("runner", {}).get("pid")
            for task in wave
        ])
    except Exception as error:
        stop_event.set()
        pids = []
        for task in wave:
            current = load_task(relay_dir, task["id"])
            pids.append(current.get("runner", {}).get("pid"))
            outcomes[task["id"]] = {
                "error": "executor_error: {}".format(error),
                "returncode": None,
            }
        terminate_process_groups(pids)
    finally:
        if executor is not None:
            executor.shutdown(wait=True, cancel_futures=True)
    if interrupted:
        for task in wave:
            outcomes[task["id"]] = {
                "interrupted": True,
                "returncode": None,
            }

    try:
        after_tree = git_snapshot(root)
        changed = git_changed_paths(root, before_tree, after_tree)
    except RuntimeError as error:
        after_tree = before_tree
        changed = []
        for task in wave:
            outcomes[task["id"]] = {"error": str(error), "returncode": None}

    wave_scopes = [scope for task in wave for scope in (task.get("scope", []) or ["**"])]
    violations = [path for path in changed if not path_in_scopes(path, wave_scopes)]
    violations_diff = git_paths_diff(root, before_tree, after_tree, violations)
    for task in wave:
        attempt = task.get("attempt", 1)
        diff = git_tree_diff(
            root, before_tree, after_tree, task.get("scope", []), changed,
        )
        directory = work_dir(relay_dir, task["id"])
        atomic_write(diff_path(relay_dir, task["id"], attempt), diff)
        if violations:
            atomic_write(
                os.path.join(directory, "attempt-%d.violations.diff" % attempt),
                violations_diff,
            )
    if violations:
        say("scope violation: " + ", ".join(violations))
    for task in wave:
        observed = [
            path for path in changed
            if path_in_scopes(path, task.get("scope", []))
        ]
        finalize_task(
            relay_dir, task, outcomes[task["id"]], violations, observed,
            before_tree, context["lease"],
        )
    if interrupted:
        raise SystemExit(interrupted_code)


